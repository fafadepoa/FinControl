# =============================================================================
# Ambiente local
# -----------------------------------------------------------------------------
# 1) Copie este arquivo para ".env" (ou rode: npm run env:init)
# 2) Preencha com valores reais. O arquivo ".env" está no .gitignore e NÃO vai
#    para o GitHub.
#
# Vercel (produção / preview)
# -----------------------------------------------------------------------------
# No painel: projeto → Settings → Environment Variables
# Cadastre as MESMAS chaves deste arquivo (valores de produção). Não é preciso
# fazer upload de um arquivo .env no repositório.
# =============================================================================

# --- Banco (Prisma) — obrigatório ---
# Dev local (exemplo; descomente e ajuste se usar Postgres local):
# DATABASE_URL="postgresql://postgres:postgres@localhost:5432/fincontrol?schema=public"
# DIRECT_URL="postgresql://postgres:postgres@localhost:5432/fincontrol?schema=public"

# Supabase (pooler + conexão direta para migrations)
DATABASE_URL="postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1&sslmode=require"
DIRECT_URL="postgresql://postgres:[password]@db.[project-ref].supabase.co:5432/postgres?sslmode=require"

# --- NextAuth / URLs da aplicação ---
AUTH_SECRET="troque-por-um-segredo-longo-aleatorio"
# Temporário para testes locais: deixe false para não exigir confirmação por e-mail no login.
# No futuro, altere para true quando o fluxo de verificação estiver ativo.
AUTH_REQUIRE_EMAIL_VERIFICATION="false"
# URL pública do app (local: http://localhost:3000 | produção: https://seu-dominio.vercel.app)
NEXTAUTH_URL="https://seu-projeto.vercel.app"
APP_BASE_URL="https://seu-projeto.vercel.app"

# --- E-mail (Resend) — opcional em dev se não for enviar e-mails ---
APP_NAME="FinControl"
APP_LOGO_URL="https://exemplo.com/logo-fincontrol.png"
MAIL_FROM="FinControl <no-reply@seu-dominio.com>"
RESEND_API_KEY="re_..."
