generator client {
  provider      = "prisma-client-js"
  // Vercel roda em Linux; incluir o alvo evita erro de query engine no deploy.
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Role {
  ADMIN
  USER
}

enum ExpenseStatus {
  PENDING
  APPROVED
  REJECTED
  PAID
}

enum CreditTransactionType {
  CREDIT
  DEBIT
  ADJUSTMENT
}

model User {
  id                           String   @id @default(cuid())
  email                        String   @unique
  passwordHash                 String
  role                         Role     @default(USER)
  active                       Boolean  @default(true)
  emailVerifiedAt              DateTime?
  /** Quando false, o próprio usuário não vê o valor numérico do saldo de crédito na UI. */
  creditBalanceVisibleToSelf   Boolean  @default(true)
  createdAt                    DateTime @default(now())
  updatedAt                    DateTime @updatedAt

  companiesCreated   Company[]           @relation("CompanyCreator")
  userCompanies      UserCompany[]
  expenses           Expense[]
  creditBalance      CreditBalance?
  creditTransactions CreditTransaction[] @relation("CreditTxUser")
  creditTxCreatedBy  CreditTransaction[] @relation("CreditTxCreatedBy")
  emailVerificationTokens EmailVerificationToken[]
  passwordResetTokens     PasswordResetToken[]
}

model Company {
  id          String   @id @default(cuid())
  name        String
  cnpj        String?
  phone       String?
  createdById String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  createdBy     User          @relation("CompanyCreator", fields: [createdById], references: [id], onDelete: Cascade)
  userCompanies UserCompany[]
  categories    Category[]
  expenses      Expense[]

  @@index([createdById])
}

model UserCompany {
  userId    String
  companyId String
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@id([userId, companyId])
  @@index([companyId])
}

model Category {
  id          String   @id @default(cuid())
  companyId   String
  name        String
  limitAmount Decimal?
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  company  Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  expenses Expense[]

  @@unique([companyId, name])
  @@index([companyId, active])
}

model Expense {
  id            String        @id @default(cuid())
  userId        String
  companyId     String
  categoryId    String
  amount        Decimal
  description   String?
  status        ExpenseStatus @default(PENDING)
  attachmentUrl String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  approvedAt    DateTime?
  paidAt        DateTime?

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  company  Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  category Category @relation(fields: [categoryId], references: [id], onDelete: Restrict)

  @@index([userId])
  @@index([companyId, status])
  @@index([status])
}

model CreditBalance {
  userId    String   @id
  balance   Decimal  @default(0)
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model CreditTransaction {
  id          String                 @id @default(cuid())
  userId      String
  amount      Decimal
  type        CreditTransactionType
  note        String?
  createdAt   DateTime               @default(now())
  createdById String?

  user      User @relation("CreditTxUser", fields: [userId], references: [id], onDelete: Cascade)
  createdBy User? @relation("CreditTxCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
}

model EmailVerificationToken {
  id        String   @id @default(cuid())
  userId    String
  tokenHash String
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([expiresAt])
  @@unique([tokenHash])
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  userId    String
  tokenHash String
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([expiresAt])
  @@unique([tokenHash])
}
