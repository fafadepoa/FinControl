generator client {
  provider      = "prisma-client-js"
  // Vercel roda em Linux; incluir o alvo evita erro de query engine no deploy.
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Role {
  ADMIN
  USER
}

enum ExpenseStatus {
  PENDING
  APPROVED
  REJECTED
  PAID
}

enum CreditTransactionType {
  CREDIT
  DEBIT
  ADJUSTMENT
}

enum FuelEntryMode {
  FREE
  DAILY
  KM
}

enum CategoryKind {
  DEFAULT
  CUSTOM
  FUEL
}

model User {
  id                           String   @id @default(cuid())
  email                        String   @unique
  /** Nome para exibição (colaborador / admin); opcional em contas antigas. */
  displayName                  String?
  /** Null enquanto colaborador não conclui convite e define senha. */
  passwordHash                 String?
  role                         Role     @default(USER)
  active                       Boolean  @default(true)
  emailVerifiedAt              DateTime?
  /** Quando false, o próprio usuário não vê o valor numérico do saldo de crédito na UI. */
  creditBalanceVisibleToSelf   Boolean  @default(true)
  createdAt                    DateTime @default(now())
  updatedAt                    DateTime @updatedAt

  companiesCreated   Company[]           @relation("CompanyCreator")
  userCompanies      UserCompany[]
  expenses           Expense[]
  creditBalance      CreditBalance?
  creditTransactions CreditTransaction[] @relation("CreditTxUser")
  creditTxCreatedBy  CreditTransaction[] @relation("CreditTxCreatedBy")
  emailVerificationTokens EmailVerificationToken[]
  collaboratorInviteTokens CollaboratorInviteToken[]
  passwordResetTokens     PasswordResetToken[]
  categoryLinks           CategoryUser[]
}

model Company {
  id          String   @id @default(cuid())
  name        String
  cnpj        String?
  phone       String?
  createdById String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  createdBy     User          @relation("CompanyCreator", fields: [createdById], references: [id], onDelete: Cascade)
  userCompanies UserCompany[]
  categories    Category[]
  expenses      Expense[]

  @@index([createdById])
}

model UserCompany {
  userId    String
  companyId String
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@id([userId, companyId])
  @@index([companyId])
}

model Category {
  id          String   @id @default(cuid())
  companyId   String
  name        String
  kind        CategoryKind @default(CUSTOM)
  /** Livre / por diária / por km — referência na categoria; valor da despesa continua manual. */
  paymentRule FuelEntryMode @default(FREE)
  /** Valor de referência por diária (obrigatório se paymentRule = DAILY em categoria FUEL). */
  dailyRate   Decimal?
  /** Valor de referência por km (obrigatório se paymentRule = KM em categoria FUEL). */
  kmRate      Decimal?
  limitAmount Decimal?
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  company  Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  expenses Expense[]
  categoryUsers CategoryUser[]

  @@unique([companyId, name])
  @@index([companyId, active])
}

model CategoryUser {
  categoryId String
  userId     String
  createdAt  DateTime @default(now())

  category Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([categoryId, userId])
  @@index([userId])
}

model Expense {
  id            String        @id @default(cuid())
  userId        String
  companyId     String
  categoryId    String
  amount        Decimal
  fuelEntryMode FuelEntryMode?
  description   String?
  status        ExpenseStatus @default(PENDING)
  attachmentUrl String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  approvedAt    DateTime?
  paidAt        DateTime?

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  company  Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  category Category @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  attachments ExpenseAttachment[]

  @@index([userId])
  @@index([companyId, status])
  @@index([status])
}

model ExpenseAttachment {
  id        String   @id @default(cuid())
  expenseId String
  url       String
  createdAt DateTime @default(now())

  expense Expense @relation(fields: [expenseId], references: [id], onDelete: Cascade)

  @@index([expenseId, createdAt])
}

model CreditBalance {
  userId    String   @id
  balance   Decimal  @default(0)
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model CreditTransaction {
  id          String                 @id @default(cuid())
  userId      String
  amount      Decimal
  type        CreditTransactionType
  balanceAfter Decimal?
  note        String?
  createdAt   DateTime               @default(now())
  createdById String?

  user      User @relation("CreditTxUser", fields: [userId], references: [id], onDelete: Cascade)
  createdBy User? @relation("CreditTxCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
}

model EmailVerificationToken {
  id        String   @id @default(cuid())
  userId    String
  tokenHash String
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([expiresAt])
  @@unique([tokenHash])
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  userId    String
  tokenHash String
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([expiresAt])
  @@unique([tokenHash])
}

model CollaboratorInviteToken {
  id        String   @id @default(cuid())
  userId    String
  tokenHash String
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([expiresAt])
  @@unique([tokenHash])
}

model LoginThrottle {
  id              String   @id @default(cuid())
  identifier      String   @unique
  attempts        Int      @default(0)
  windowStartedAt DateTime @default(now())
  blockedUntil    DateTime?
  lastAttemptAt   DateTime @default(now())
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([blockedUntil])
  @@index([lastAttemptAt])
}

model AuthAuditEvent {
  id         String   @id @default(cuid())
  email      String?
  ip         String?
  event      String
  reason     String?
  createdAt  DateTime @default(now())

  @@index([createdAt])
  @@index([event, createdAt])
}
